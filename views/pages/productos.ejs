<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div>
            <h1>Productos</h1>
            <table id="tabla" class="table table-striped">
                <thead>
                    <th>Stock</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Acciones</th>
                </thead>
                <tbody>
                    <% productos.forEach(function(producto) { %>
                        <tr>
                            <td>
                                <%= producto.stock %>
                            </td>
                            <td>
                                <%= producto.nombre %>
                            </td>
                            <td>
                                <%= producto.precio %>
                            </td>
                            <td>
                                <a href="/productos/eliminar/<%= producto._id %>" class="btn btn-danger btn-sm"
                                    onclick="return confirm('¿Deseas eliminar este producto?')">
                                    Eliminar
                                </a>

                                <a href="#" class="btn btn-info btn-sm">Actualizar</a>

                                <a href="#" class="btn btn-info btn-sm" data-bs-toggle="modal"
                                    data-bs-target="#modal_ver_detalle<%= producto._id %>">Ver Detalles</a>
                            </td>
                        </tr>

                        <div class="modal fade" id="modal_ver_detalle<%= producto._id %>" tabindex="-1"
                            aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Detalles de: <%= producto.nombre %>
                                        </h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                            aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p><strong>Nombre del Producto:</strong>
                                            <%= producto.nombre %>
                                        </p>
                                        <p><strong>Precio:</strong> $<%= producto.precio %>
                                        </p>
                                        <p><strong>Stock Disponible:</strong>
                                            <%= producto.stock %> unidades
                                        </p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary"
                                            data-bs-dismiss="modal">CERRAR</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

</html>